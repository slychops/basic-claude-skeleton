# ----------------------------------------------------------------------------
# Basic Claude Skeleton — .gitignore
#
# Sensible defaults for a Godot 4 + Claude Code project, plus the usual macOS
# / IDE / scripting noise. Append project-specific entries at the bottom.
# ----------------------------------------------------------------------------

# --- Godot 4 ---
# Editor cache, generated metadata, and platform exports. The .godot/ folder
# is regenerated on first open; .import files are regenerated by the engine.
.godot/
.import/
*.translation
export.cfg
export_presets.cfg
*.gd.uid.bak

# Built/exported binaries — adjust per platform if you commit any of these.
/bin/
/build/
/dist/
/exports/
*.pck
*.zip
*.dmg
*.exe
*.app

# Godot crash logs
logs/

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# --- Windows ---
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Linux ---
*~
.fuse_hidden*
.nfs*

# --- Editors / IDEs ---
.vscode/
.idea/
*.iml
*.swp
*.swo
*~.nib
.history/

# --- JetBrains Rider / Godot C# ---
.mono/
mono_crash.*.json
*.csproj.user
*.suo

# --- Node (web dashboards, tooling) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
.yarn/

# --- Python (asset pipelines, CLI tools) ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
develop-eggs/
dist/
sdist/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Environment / secrets ---
.env
.env.*
!.env.example
*.pem
*.key

# --- Logs and tmp ---
*.log
*.tmp
*.bak
*.orig
.cache/

# --- Claude Code ---
# Personal/local Claude settings stay out of source control; the project-wide
# .claude/skills/ and .claude/agents/ folders are intentionally committed.
.claude/settings.local.json
.claude/projects/
.claude/transcripts/
